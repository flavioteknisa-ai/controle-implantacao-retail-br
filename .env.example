# Copie este arquivo para .env e preencha os valores

# Chave secreta da sessão (gere uma string aleatória longa)
SECRET_KEY=troque-por-uma-chave-secreta-longa

# Credenciais do admin inicial (criado automaticamente no primeiro boot)
ADMIN_USER=admin
ADMIN_PASSWORD=troque-a-senha

# URL do banco de dados
# SQLite local (padrão):
# DATABASE_URL=sqlite:///data/ferias_data.db
# PostgreSQL (Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
